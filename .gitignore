# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
**/.next/

# production
/build
**/node_modules/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secrets and local credentials
paperclip-api-key.json
.discord-webhook.json
*.key
*.token

# runtime artifacts
memory/
.openclaw/
workspace/
*.db
*.sqlite

# local subdirectory copy of control-panel (root is canonical)
control-panel/

# macOS
*.alias
~$*
